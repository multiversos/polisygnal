NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# This frontend does not connect directly to Neon or Supabase today.
# Keep Postgres URLs and service keys server-only in the backend environment.

# Optional server-side Analysis Agent Bridge for Deep Analyzer research.
# Generic ANALYSIS_AGENT_* variables take priority over legacy SAMANTHA_BRIDGE_*.
ANALYSIS_AGENT_PROVIDER=samantha
ANALYSIS_AGENT_ENABLED=false
# Production must use a public HTTPS agent URL, never localhost.
# ANALYSIS_AGENT_URL=https://<agent-host>/polysignal/analyze-market
# ANALYSIS_AGENT_TOKEN=
ANALYSIS_AGENT_DISPLAY_NAME=Samantha
ANALYSIS_AGENT_ALLOW_LOCALHOST=false
# ANALYSIS_AGENT_ALLOWED_PORTS=8787
# ANALYSIS_AGENT_TIMEOUT_MS=25000
# ANALYSIS_AGENT_MAX_REQUEST_BYTES=90000
# ANALYSIS_AGENT_MAX_RESPONSE_BYTES=120000

# Legacy Samantha bridge compatibility for Deep Analyzer research.
# Keep these until production has migrated to ANALYSIS_AGENT_*.
SAMANTHA_BRIDGE_ENABLED=false
# Production must use a public HTTPS bridge URL, never localhost.
# SAMANTHA_BRIDGE_URL=https://<samantha-bridge-host>/polysignal/analyze-market
# Recommended local/dev endpoint:
# SAMANTHA_BRIDGE_URL=http://127.0.0.1:8787/polysignal/analyze-market
# SAMANTHA_BRIDGE_TOKEN=
# SAMANTHA_BRIDGE_ALLOW_LOCALHOST=false
# SAMANTHA_BRIDGE_ALLOWED_PORTS=8787
# SAMANTHA_BRIDGE_TIMEOUT_MS=25000
# SAMANTHA_BRIDGE_MAX_REQUEST_BYTES=90000
# SAMANTHA_BRIDGE_MAX_RESPONSE_BYTES=120000

# Optional server-side external odds provider trial for NBA comparisons.
ODDS_PROVIDER_ENABLED=false
ODDS_PROVIDER_NAME=OddsBlaze
ODDS_PROVIDER_BASE_URL=https://odds.oddsblaze.com/
ODDS_PROVIDER_API_KEY=
ODDS_PROVIDER_AUTH_MODE=query
ODDS_PROVIDER_SPORTSBOOK=draftkings
ODDS_PROVIDER_LEAGUE=nba
ODDS_PROVIDER_TIMEOUT_MS=10000
ODDS_PROVIDER_TRIAL_MODE=true
