POLYSIGNAL_ENV=development
POLYSIGNAL_API_HOST=0.0.0.0
POLYSIGNAL_API_PORT=8000
POLYSIGNAL_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/polysignal
POLYSIGNAL_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
POLYSIGNAL_POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYSIGNAL_POLYMARKET_TIMEOUT_SECONDS=20
POLYSIGNAL_POLYMARKET_PAGE_LIMIT=100
POLYSIGNAL_KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
POLYSIGNAL_KALSHI_TIMEOUT_SECONDS=20
POLYSIGNAL_CLOB_BASE_URL=https://clob.polymarket.com
POLYSIGNAL_CLOB_TIMEOUT_SECONDS=20
POLYSIGNAL_POLYMARKET_USER_AGENT=PolySignal/0.1
POLYSIGNAL_MVP_DISCOVERY_SCOPE=nba
POLYSIGNAL_POLYMARKET_SPORTS_TAG_ID=1
POLYSIGNAL_POLYMARKET_NBA_TAG_ID=745
POLYSIGNAL_SNAPSHOT_BATCH_SIZE=50
POLYSIGNAL_SNAPSHOT_HISTORY_DEFAULT_LIMIT=10
POLYSIGNAL_SNAPSHOT_HISTORY_MAX_LIMIT=100
ODDS_API_KEY=
POLYSIGNAL_ODDS_API_BASE_URL=https://api.the-odds-api.com
POLYSIGNAL_ODDS_API_TIMEOUT_SECONDS=20
POLYSIGNAL_ODDS_API_REGIONS=us
POLYSIGNAL_ODDS_API_MARKETS=h2h
POLYSIGNAL_ODDS_HIGH_CONTRADICTION_DELTA=0.10
POLYSIGNAL_ESPN_NBA_RSS_URL=https://www.espn.com/espn/rss/nba/news
POLYSIGNAL_ESPN_RSS_TIMEOUT_SECONDS=20
POLYSIGNAL_EVIDENCE_NEWS_SUMMARY_MAX_LENGTH=280
POLYSIGNAL_SCORING_MODEL_VERSION=scoring_v1
POLYSIGNAL_SCORING_ODDS_WINDOW_HOURS=24
POLYSIGNAL_SCORING_NEWS_WINDOW_HOURS=48
POLYSIGNAL_SCORING_FRESHNESS_WINDOW_HOURS=24
POLYSIGNAL_SCORING_LOW_LIQUIDITY_THRESHOLD=50000
OPENAI_API_KEY=
OPENAI_RESEARCH_ENABLED=true
OPENAI_RESEARCH_MODEL=gpt-5-mini
OPENAI_RESEARCH_TIMEOUT_SECONDS=45
OPENAI_RESEARCH_MAX_SOURCES=6
OPENAI_RESEARCH_ALLOWED_DOMAINS=nba.com,espn.com,basketball-reference.com,statmuse.com,apnews.com,reuters.com
OPENAI_RESEARCH_BLOCKED_DOMAINS=
