POLYSIGNAL_LINEAR_OAUTH_TOKEN_URL=https://api.linear.app/oauth/token
POLYSIGNAL_LINEAR_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/callback
POLYSIGNAL_LINEAR_OAUTH_SCOPES=read,write
POLYSIGNAL_LINEAR_OAUTH_ACTOR=user
POLYSIGNAL_LINEAR_OAUTH_CREDENTIALS_PATH=.linear/oauth-credentials.json
